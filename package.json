{
  "name": "contas-domesticas-front",
  "version": "0.0.1",
  "description": "Frontend web do Contas Domesticas (Vue 3 + Quasar + TypeScript)",
  "productName": "Contas Domesticas",
  "author": "Bruno Oliveira",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "quasar dev",
    "dev:pwa": "quasar dev -m pwa",
    "build": "quasar build",
    "build:pwa": "quasar build -m pwa",
    "lint": "eslint --ext .js,.ts,.vue ./src",
    "format": "prettier --write \"src/**/*.{js,ts,vue,scss}\"",
    "typecheck": "vue-tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "cypress run",
    "prepare": "husky"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.12",
    "@tanstack/vue-query": "^5.51.0",
    "@vee-validate/zod": "^4.13.2",
    "@vueuse/core": "^10.11.0",
    "axios": "^1.7.2",
    "axios-retry": "^4.4.2",
    "big.js": "^6.2.1",
    "date-fns": "^3.6.0",
    "echarts": "^5.5.1",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.1",
    "quasar": "^2.16.0",
    "register-service-worker": "^1.7.2",
    "vee-validate": "^4.13.2",
    "vue": "^3.4.18",
    "vue-echarts": "^7.0.3",
    "vue-i18n": "^9.13.1",
    "vue-router": "^5.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@pinia/testing": "^0.1.3",
    "@quasar/app-vite": "^1.9.0",
    "@quasar/cli": "^2.4.1",
    "@types/big.js": "^6.2.2",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.19",
    "cypress": "^13.13.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.25.0",
    "husky": "^9.0.11",
    "jsdom": "^24.1.0",
    "lint-staged": "^15.2.7",
    "postcss": "^8.4.38",
    "prettier": "^3.3.2",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.0.26"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "eslint --fix",
    "*.{js,ts,vue,scss,json,md}": "prettier --write"
  },
  "engines": {
    "node": "^18 || ^20 || ^22",
    "npm": ">= 8"
  }
}
