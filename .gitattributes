# Normaliza fim de linha: texto em LF no repositorio.
* text=auto eol=lf

# Scripts Windows permanecem CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binarios (nunca normalizar).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
